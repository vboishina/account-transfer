<?xml version="1.0" encoding="UTF-8"?>

<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="
        http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.0.xsd">
    <changeSet id="005-create-ledger-table" author="admin">
        <createTable
                schemaName="ACCOUNT_TRANSFER"
                tableName="ledger_entry">
            <column name="id" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true"/>
            </column>
            <column name="transfer_id" type="BIGINT"/>
            <column name="iban" type="VARCHAR(34)"/>
            <column name="entry_type" type="VARCHAR(10)"/>
            <column name="amount" type="DECIMAL(15,2)"/>
            <column name="currency" type="VARCHAR(3)"/>
            <column name="created_at" type="TIMESTAMP"/>
        </createTable>
    </changeSet>
</databaseChangeLog>